groups:
  - name: instance_health
    interval: 30s
    rules:
      # Alert when container CPU usage is high
      - alert: HighContainerCPU
        expr: sum(rate(container_cpu_usage_seconds_total{name!=""}[5m])) by (name) > 0.8
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High CPU usage on container {{ $labels.name }}"
          description: "Container {{ $labels.name }} has CPU usage above 80% for 5 minutes"

      # Alert when memory usage is high
      - alert: HighMemoryUsage
        expr: sum(container_memory_working_set_bytes{name!=""}) by (name) / sum(container_spec_memory_limit_bytes{name!=""}) by (name) > 0.9
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High memory usage on container {{ $labels.name }}"
          description: "Container {{ $labels.name }} has memory usage above 90%"

      # Alert when API latency is high
      - alert: HighAPILatency
        expr: histogram_quantile(0.99, sum(rate(nginx_http_request_duration_seconds_bucket[5m])) by (le, service)) > 2
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High API latency for {{ $labels.service }}"
          description: "99th percentile latency for {{ $labels.service }} is above 2 seconds"

      # Alert when service is down
      - alert: ServiceDown
        expr: up{job!="prometheus"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Service {{ $labels.job }} is down"
          description: "Service {{ $labels.job }} has been down for more than 1 minute"

      # Alert when disk usage is high
      - alert: HighDiskUsage
        expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 10
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Low disk space on EC2 instance"
          description: "Only {{ $value }}% disk space remaining"
